# Copy this file to ".env" and fill in your values.

# --- Local telemetry (.ibt) — the active pipeline ---
# Folder the sim writes .ibt files to. On the Windows sim box this is usually
# ~/Documents/iRacing/telemetry. If you copy files to this Mac, point this at
# wherever you put them (or just pass a file path as an argument).
IRACING_TELEMETRY_DIR=~/Documents/iRacing/telemetry

# --- Strategy projection (optional; CLI flags override these) ---
# Race length for the Strategy + Race Sim tabs. Leave blank to use the length
# from the file (when it is a real race). Set one to plan an upcoming race from
# a practice run. Use RACE_HOURS for endurance (e.g. 6).
RACE_LAPS=
RACE_MINUTES=
RACE_HOURS=
# Fuel safety reserve kept in hand, in laps (default 0.3).
FUEL_MARGIN_LAPS=0.3
# Seconds lost per pit stop (default 30).
PIT_LOSS_SECONDS=30

# --- Race simulation (optional; CLI flags override) ---
# Override tyre degradation (seconds added per lap of a stint). Blank = measured
# from the file's stints.
SIM_DEG_PER_LAP=
# Add to fresh-lap pace in the sim (+ = fuel/tyre saving, slower). Default 0.
SIM_PACE_OFFSET=0
# Cap stint length by time (minutes) for a tyre/driver limit. Blank = fuel-limited.
MAX_STINT_MINUTES=
# Number of drivers (endurance) — reports stints per driver. Blank = ignore.
DRIVERS=
# Seconds added per green lap from traffic (default 0 = clean air).
TRAFFIC_LOSS=0
# Expected safety-car periods, shown as a sensitivity range (default 0).
SAFETY_CARS=0
# Minutes per safety-car period (default 5).
SC_MINUTES=5
# Fraction of normal pit loss still paid when pitting under SC (default 0.4).
SC_PIT_DISCOUNT=0.4

# --- Google Sheets ---
# Path to the service-account JSON key you downloaded (see README).
GOOGLE_CREDENTIALS_PATH=service_account.json

# OPTION A: leave GOOGLE_SHEET_ID blank and set GOOGLE_SHARE_EMAIL.
# The script creates a NEW spreadsheet each run and shares it with you.
GOOGLE_SHARE_EMAIL=you@gmail.com

# OPTION B: reuse one existing spreadsheet. Create a blank sheet in your
# Drive, share it (Editor) with the service-account email, and paste its
# id here (the long string in the sheet URL between /d/ and /edit).
GOOGLE_SHEET_ID=

# --- iRacing web /data API (OPTIONAL — alternative path, currently blocked) ---
# Only needed if you use the web Data API path (iracing_client.py) instead of
# .ibt files. That path requires OAuth2; iRacing has paused issuing new client
# IDs, so leave these blank unless you already hold credentials.
IRACING_CLIENT_ID=
IRACING_CLIENT_SECRET=
IRACING_EMAIL=
IRACING_PASSWORD=
IRACING_CUST_ID=
IRACING_TOKEN_CACHE=.iracing_tokens.json
