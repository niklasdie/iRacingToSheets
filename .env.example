# Copy this file to ".env" and fill in your values.

# --- iRacing (OAuth2) ---
# Legacy email/password auth was removed 2025-12-09; the Data API now needs
# OAuth2. The CLIENT_ID/SECRET come from a registered OAuth client. NOTE:
# iRacing has paused issuing new client IDs — check
# https://oauth.iracing.com/accountmanagement/ for existing credentials.
IRACING_CLIENT_ID=
IRACING_CLIENT_SECRET=

IRACING_EMAIL=you@example.com
IRACING_PASSWORD=your-iracing-password
# Your iRacing customer id (find it on your iRacing profile page).
# Required for "latest race" mode and for the "My Laps" analysis.
IRACING_CUST_ID=123456

# Where to cache OAuth tokens between runs (so you don't re-auth every time).
IRACING_TOKEN_CACHE=.iracing_tokens.json

# --- Google Sheets ---
# Path to the service-account JSON key you downloaded (see README).
GOOGLE_CREDENTIALS_PATH=service_account.json

# OPTION A: leave GOOGLE_SHEET_ID blank and set GOOGLE_SHARE_EMAIL.
# The script creates a NEW spreadsheet each run and shares it with you.
GOOGLE_SHARE_EMAIL=you@gmail.com

# OPTION B: reuse one existing spreadsheet. Create a blank sheet in your
# Drive, share it (Editor) with the service-account email, and paste its
# id here (the long string in the sheet URL between /d/ and /edit).
GOOGLE_SHEET_ID=
